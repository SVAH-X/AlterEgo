# ============================================================
# AlterEgo — environment template
# Copy to .env and fill in real values. Never commit .env.
# ============================================================

# --- Inference plan (B = hosted APIs, A = local on ASUS GX10) ---
INFERENCE_PLAN=B

# --- Anthropic (Plan B: future-self, high-signal, peers) ---
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL_FUTURE_SELF=claude-opus-4-7
ANTHROPIC_MODEL_HIGH_SIGNAL=claude-sonnet-4-6
ANTHROPIC_MODEL_PEERS=claude-haiku-4-5

# --- Groq (Plan B: noise / misinfo tier) ---
GROQ_API_KEY=gsk_...
GROQ_MODEL_NOISE=llama-3.1-8b-instant

# --- Plan A: ASUS GX10 local inference (only if hardware in hand) ---
# OpenAI-compatible endpoint(s) served by vLLM / llama.cpp / Ollama.
# Specific model identifiers TBD after first hardware bringup.
GX10_BASE_URL=http://localhost:8001/v1
GX10_API_KEY=local-no-key
GX10_MODEL_FUTURE_SELF=
GX10_MODEL_HIGH_SIGNAL=
GX10_MODEL_PEERS=
GX10_MODEL_NOISE=

# --- ElevenLabs (voiced future-self interview) ---
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# --- MongoDB Atlas (single DB: checkpoint ledger + agent state + vector search) ---
MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=alterego

# --- Cloudinary (share cards, timeline media) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Replicate (face aging via SAM model) ---
REPLICATE_API_TOKEN=

# --- Ready Player Me (selfie -> 3D avatar) ---
READY_PLAYER_ME_SUBDOMAIN=

# --- GDELT (real-news ingestion; no key needed) ---
GDELT_API_BASE=https://api.gdeltproject.org/api/v2

# --- Fetch.ai Agentverse (optional; only if pursuing the track) ---
AGENTVERSE_API_KEY=
AGENT_SEED=

# --- Server ---
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:3000
LOG_LEVEL=INFO
