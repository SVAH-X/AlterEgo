# ============================================================
# AlterEgo — environment template
# Copy to .env and fill in real values. Never commit .env.
# ============================================================

# --- Inference plan (B = hosted APIs, A = local on ASUS GX10) ---
INFERENCE_PLAN=B

# --- Anthropic (required for /simulate and /chat) ---
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL_FUTURE_SELF=claude-opus-4-7
ANTHROPIC_MODEL_HIGH_SIGNAL=claude-sonnet-4-6
ANTHROPIC_MODEL_PEERS=claude-haiku-4-5

# --- Groq (router noise tier; not used by the MVP path) ---
GROQ_API_KEY=
GROQ_MODEL_NOISE=llama-3.1-8b-instant

# --- ElevenLabs (required for /tts, /stt, /voice/clone, /chat/voice) ---
# ELEVENLABS_VOICE_ID is the default voice used when no cloned voice is active
# (e.g. intake prompts spoken to the user). The future-self uses a per-session
# IVC clone of the user's own voice; we fall back to this default if cloning
# is skipped or fails.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# --- Gemini (image generation for aged portraits) ---
# Use a cheaper image model during dev, the polished one on demo day.
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# --- Plan A: ASUS GX10 (only if hardware in hand; models TBD after bringup) ---
GX10_BASE_URL=http://localhost:8001/v1
GX10_API_KEY=local-no-key
GX10_MODEL_FUTURE_SELF=
GX10_MODEL_HIGH_SIGNAL=
GX10_MODEL_PEERS=
GX10_MODEL_NOISE=

# --- Server ---
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:5173
LOG_LEVEL=INFO
